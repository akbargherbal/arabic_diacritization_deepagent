{"verse_id": "v_001", "sadr": "لخولة أطلال ببرقة ثهمد", "ajuz": "تلوح كباقي الوشم في ظاهر اليد", "meter": "taweel"}
{"verse_id": "v_002", "sadr": "بروضة دعمي فأكناف حائل", "ajuz": "ظللت بها أبكي وأبكي إلى الغد", "meter": "taweel"}
{"verse_id": "v_003", "sadr": "وقوفا بها صحبي علي مطيهم", "ajuz": "يقولون لا تهلك أسى وتجلد", "meter": "taweel"}
{"verse_id": "v_004", "sadr": "كأن حدوج المالكية غدوة", "ajuz": "خلايا سفين بالنواصف من دد", "meter": "taweel"}
{"verse_id": "v_005", "sadr": "عدولية أو من سفينبن يامن", "ajuz": "يجور بها الملاح طورا ويهتدي", "meter": "taweel"}
{"verse_id": "v_006", "sadr": "يشق حباب الماء حيزومها بها", "ajuz": "كما قسم الترب المفايل باليد", "meter": "taweel"}
{"verse_id": "v_007", "sadr": "وفي الحي أحوى ينفض المرد شادن", "ajuz": "مظاهر سمطي لؤلؤ وزبرجد", "meter": "taweel"}
{"verse_id": "v_008", "sadr": "خذول تراعي ربربا بخميلة", "ajuz": "تناول أطراف البرير وترتدي", "meter": "taweel"}
{"verse_id": "v_009", "sadr": "وتبسم عن ألمى كأن منورا", "ajuz": "تخلل حر الرمل دعص له ند", "meter": "taweel"}
{"verse_id": "v_010", "sadr": "سقته إياة الشمس إلا لثاته", "ajuz": "أسف ولم تكدم عليه بإثمد", "meter": "taweel"}
{"verse_id": "v_011", "sadr": "ووجه كأن الشمس حلت رداءها", "ajuz": "عليه نقي لون لم يتخدد", "meter": "taweel"}
{"verse_id": "v_012", "sadr": "وإني لأمضي الهم عند احتضاره", "ajuz": "بعوجاء مرقال تروح وتغتدي", "meter": "taweel"}
